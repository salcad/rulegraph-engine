# Copy to .env (next to docker-compose.yml) and fill in before deploying:  cp .env.example .env
# Docker Compose reads .env automatically for the ${...} values in docker-compose.yml.

# Neo4j password for the database and the backend's connection. CHANGE THIS before exposing the
# deployment publicly; the compose default (password123) is only for local development.
NEO4J_PASSWORD=password123

# OpenRouter API key for the LLM rule extractor. Leave blank to fall back to the seed extractor
# (a missing key won't block boot). Only used when RULEGRAPH_LLM_ENABLED=true.
OPENROUTER_API_KEY=

# Set to true to enable the LLM rule extractor (requires OPENROUTER_API_KEY). Defaults to false.
RULEGRAPH_LLM_ENABLED=false
